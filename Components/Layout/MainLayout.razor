@inherits LayoutComponentBase
@inject DataStore Store
@inject DraftService Drafts
@inject ExportService ExportSvc
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="h-editor-shell">
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">🎮</div>
            <div>
                <div class="sidebar-brand-text">H-Editor</div>
                <div class="sidebar-brand-sub">Hoheup Data Editor</div>
            </div>
        </div>

        <ul class="sidebar-nav">
            <li><NavLink href="" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span> 홈
            </NavLink></li>
            <li><NavLink href="master-data">
                <span class="nav-icon">📊</span> 마스터데이터
            </NavLink></li>

            <li class="nav-section">게임 데이터</li>
            <li><NavLink href="game-events">
                <span class="nav-icon">📖</span> 이벤트
                <span style="margin-left:auto;font-size:10px;color:var(--text-muted)">@Store.GameEvents.Count</span>
            </NavLink></li>
            <li><NavLink href="game-items">
                <span class="nav-icon">🎒</span> 아이템
                <span style="margin-left:auto;font-size:10px;color:var(--text-muted)">@Store.GameItems.Count</span>
            </NavLink></li>

            <li class="nav-section">배틀 데이터</li>
            <li><NavLink href="game-units">
                <span class="nav-icon">⚔️</span> 유닛
                <span style="margin-left:auto;font-size:10px;color:var(--text-muted)">@Store.GameUnits.Count</span>
            </NavLink></li>
            <li><NavLink href="monster-data">
                <span class="nav-icon">👾</span> 몬스터
                <span style="margin-left:auto;font-size:10px;color:var(--text-muted)">@Store.MonsterDatas.Count</span>
            </NavLink></li>
            <li><NavLink href="dice-data">
                <span class="nav-icon">🎲</span> 주사위
                <span style="margin-left:auto;font-size:10px;color:var(--text-muted)">@Store.DiceDatas.Count</span>
            </NavLink></li>
            <li><NavLink href="monster-groups">
                <span class="nav-icon">👾</span> 몬스터 그룹
                <span style="margin-left:auto;font-size:10px;color:var(--text-muted)">@Store.MonsterGroups.Count</span>
            </NavLink></li>
            <li><NavLink href="battle-data">
                <span class="nav-icon">🔥</span> 배틀 데이터
                <span style="margin-left:auto;font-size:10px;color:var(--text-muted)">@Store.BattleDatas.Count</span>
            </NavLink></li>
        </ul>

        <div class="sidebar-global-actions">
            <button class="btn btn-success btn-sm global-export-btn"
                    @onclick="ExportDownload">
                EXPORTED.bytes 다운로드
            </button>
        </div>

        <div class="sidebar-bottom">
            <div class="sidebar-stat-grid">
                <div class="sidebar-stat">
                    <div class="sidebar-stat-num">@Store.GameEvents.Count</div>
                    <div class="sidebar-stat-label">이벤트</div>
                </div>
                <div class="sidebar-stat">
                    <div class="sidebar-stat-num">@Store.GameItems.Count</div>
                    <div class="sidebar-stat-label">아이템</div>
                </div>
                <div class="sidebar-stat">
                    <div class="sidebar-stat-num">@Store.GameUnits.Count</div>
                    <div class="sidebar-stat-label">유닛</div>
                </div>
                <div class="sidebar-stat">
                    <div class="sidebar-stat-num">@Store.BattleDatas.Count</div>
                    <div class="sidebar-stat-label">배틀</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Store.StatusMessage))
            {
                <div class="sidebar-status @(Store.StatusIsError ? "status-error" : "status-ok")">
                    @Store.StatusMessage
                </div>
            }
        </div>
    </nav>

    <!-- Main content -->
    <main class="main-content">
        @Body
    </main>
</div>

@code {
    CancellationTokenSource? _autosaveCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            if (await Drafts.RestoreIfEmptyAsync())
            {
                Store.SetStatus("임시저장 데이터 자동 복구됨");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Store.SetStatus($"임시저장 복구 실패: {ex.Message}", true);
            StateHasChanged();
        }

        _autosaveCts = new CancellationTokenSource();
        _ = AutoSaveLoop(_autosaveCts.Token);
    }

    async Task AutoSaveLoop(CancellationToken token)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(8));

        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                try
                {
                    if (await Drafts.SaveAsync())
                    {
                        Store.SetStatus("임시저장 완료");
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch (Exception ex)
                {
                    Store.SetStatus($"임시저장 실패: {ex.Message}", true);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    async Task ExportDownload()
    {
        try
        {
            var bytes = ExportSvc.Export();
            var b64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadBytes", "EXPORTED.bytes", b64);
            await Drafts.SaveAsync(force: true);
            Store.SetStatus("EXPORTED.bytes 다운로드 시작됨");
        }
        catch (Exception ex)
        {
            Store.SetStatus($"다운로드 실패: {ex.Message}", true);
        }
    }

    public ValueTask DisposeAsync()
    {
        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
