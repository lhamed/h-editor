@page "/game-items"
@inject DataStore Store

<PageTitle>아이템 — H-Editor</PageTitle>

<div class="page-layout">
    <!-- ─── 목록 ─────────────────────────────────────────────────────────── -->
    <div class="list-panel">
        <div class="list-panel-header">
            <span>아이템 (@Store.GameItems.Count)</span>
            <button class="btn btn-success btn-sm" @onclick="CreateItem">+ 새로 만들기</button>
        </div>
        <div class="list-scroll">
            @foreach (var item in Store.GameItems.OrderBy(i => i.Key))
            {
                var langFirst = Store.GetLanguageColumns().FirstOrDefault();
                var txt = langFirst != null ? Store.LookupText(item.NameKey, langFirst) : null;
                <div class="list-item @(_selected == item ? "active" : "")"
                     @onclick="() => _selected = item">
                    <div class="list-item-key">Key: @item.Key</div>
                    <div class="list-item-name">@(txt ?? (string.IsNullOrEmpty(item.NameKey) ? "(이름 없음)" : item.NameKey))</div>
                </div>
            }
        </div>
    </div>

    <!-- ─── 상세 편집 ─────────────────────────────────────────────────────── -->
    @if (_selected == null)
    {
        <div class="empty-detail">아이템을 선택하거나 새로 만드세요</div>
    }
    else
    {
        var item = _selected;
        var langs = Store.GetLanguageColumns();
        <div class="detail-panel">
            <div class="d-flex justify-between align-center" style="margin-bottom:14px">
                <div class="page-title" style="font-size:16px">GameItem 편집</div>
                <button class="btn btn-danger btn-sm" @onclick="() => DeleteItem(item)">삭제</button>
            </div>

            <!-- Key -->
            <div class="section-card">
                <div class="section-card-header">Key</div>
                <div class="section-card-body">
                    <div class="form-group">
                        <label>Key (long)</label>
                        <input type="number"
                               value="@item.Key"
                               @onchange="@(e => { if (long.TryParse(e.Value?.ToString(), out long v)) item.Key = v; })"
                               class="@(Store.HasDuplicateItemKey(item.Key, item) ? "key-invalid" : item.Key > 0 ? "key-valid" : "key-missing")" />
                        @if (Store.HasDuplicateItemKey(item.Key, item))
                        { <div class="text-danger text-xs mt-1">중복된 Key가 존재합니다.</div> }
                        @if (item.Key <= 0)
                        { <div class="text-danger text-xs mt-1">Key는 1 이상이어야 합니다.</div> }
                    </div>
                </div>
            </div>

            <!-- 텍스트 키 -->
            <div class="section-card">
                <div class="section-card-header">로컬라이제이션 키</div>
                <div class="section-card-body">
                    <div class="form-group">
                        <label>NameKey (이름)</label>
                        <input type="text" @bind="item.NameKey" placeholder="item.name.xxx" />
                        @foreach (var lang in langs)
                        {
                            var t = Store.LookupText(item.NameKey, lang);
                            <div class="text-preview @(t != null ? "found" : "missing")">
                                [@lang] @(t ?? $"키 '{item.NameKey}' 없음")
                            </div>
                        }
                    </div>
                    <div class="form-group">
                        <label>DescriptionKey (설명)</label>
                        <input type="text" @bind="item.DescriptionKey" placeholder="item.desc.xxx" />
                        @foreach (var lang in langs)
                        {
                            var t = Store.LookupText(item.DescriptionKey, lang);
                            <div class="text-preview @(t != null ? "found" : "missing")">
                                [@lang] @(t ?? $"키 '{item.DescriptionKey}' 없음")
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- 속성 -->
            <div class="section-card">
                <div class="section-card-header">아이템 속성</div>
                <div class="section-card-body">
                    <div class="form-check">
                        <input type="checkbox" @bind="item.Stackable" id="chk-stack" />
                        <label for="chk-stack">Stackable (여러 개 보유 가능)</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" @bind="item.Usable" id="chk-use" />
                        <label for="chk-use">Usable (게임 내 사용 가능)</label>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    GameItemData? _selected;

    void CreateItem()
    {
        long nextKey = Store.GameItems.Count > 0 ? Store.GameItems.Max(i => i.Key) + 1 : 1;
        var item = new GameItemData { Key = nextKey };
        Store.GameItems.Add(item);
        _selected = item;
    }

    void DeleteItem(GameItemData item)
    {
        Store.GameItems.Remove(item);
        if (_selected == item) _selected = null;
    }
}
