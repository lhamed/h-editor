@page "/"
@inject DataStore Store
@inject ExportService ExportSvc
@inject IJSRuntime JS

<PageTitle>H-Editor</PageTitle>

<div class="detail-panel">
<div class="home-wrapper">

    @if (!string.IsNullOrEmpty(_msg))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success")" style="margin-bottom:16px">
            <span>@(_isError ? "⚠️" : "✅")</span>
            <span>@_msg</span>
        </div>
    }

    <!-- Hero -->
    <div class="home-hero">
        <div class="home-hero-icon">🎮</div>
        <div>
            <div class="home-hero-title">H-Editor</div>
            <div class="home-hero-sub">Hoheup 게임 데이터 편집 도구 — Unity ↔ EXPORTED.bytes</div>
        </div>
    </div>

    <!-- 통계 -->
    <div class="home-stat-grid">
        <a class="home-stat-card" href="game-events">
            <div class="home-stat-icon">📖</div>
            <div class="home-stat-num">@Store.GameEvents.Count</div>
            <div class="home-stat-label">게임 이벤트</div>
        </a>
        <a class="home-stat-card" href="game-items">
            <div class="home-stat-icon">🎒</div>
            <div class="home-stat-num">@Store.GameItems.Count</div>
            <div class="home-stat-label">아이템</div>
        </a>
        <a class="home-stat-card" href="game-units">
            <div class="home-stat-icon">⚔️</div>
            <div class="home-stat-num">@Store.GameUnits.Count</div>
            <div class="home-stat-label">유닛</div>
        </a>
        <a class="home-stat-card" href="monster-data">
            <div class="home-stat-icon">👾</div>
            <div class="home-stat-num">@Store.MonsterDatas.Count</div>
            <div class="home-stat-label">몬스터</div>
        </a>
        <a class="home-stat-card" href="dice-data">
            <div class="home-stat-icon">🎲</div>
            <div class="home-stat-num">@Store.DiceDatas.Count</div>
            <div class="home-stat-label">주사위</div>
        </a>
        <a class="home-stat-card" href="monster-groups">
            <div class="home-stat-icon">👾</div>
            <div class="home-stat-num">@Store.MonsterGroups.Count</div>
            <div class="home-stat-label">몬스터 그룹</div>
        </a>
        <a class="home-stat-card" href="battle-data">
            <div class="home-stat-icon">🔥</div>
            <div class="home-stat-num">@Store.BattleDatas.Count</div>
            <div class="home-stat-label">배틀 데이터</div>
        </a>
    </div>

    <!-- Import / Export -->
    <div class="io-grid">
        <!-- Import -->
        <div class="io-card">
            <div class="io-card-title">
                <span class="io-card-icon">📥</span>
                Import
            </div>
            <p class="text-sm text-dim" style="margin:0 0 10px">
                Unity에서 Export한 <code>EXPORTED.bytes</code>를 불러옵니다.
            </p>
            <InputFile OnChange="HandleImport" style="color:var(--text);font-size:12px" />
        </div>

        <!-- Export -->
        <div class="io-card">
            <div class="io-card-title">
                <span class="io-card-icon">📤</span>
                Export
            </div>
            <p class="text-sm text-dim" style="margin:0 0 10px">
                편집한 데이터를 <code>EXPORTED.bytes</code>로 다운로드합니다.
            </p>
            <button class="btn btn-success btn-lg w-100" @onclick="ExportDownload">
                ⬇ EXPORTED.bytes 다운로드
            </button>
        </div>
    </div>

    <!-- M.bytes -->
    <div class="section-card">
        <div class="section-card-header">
            <span><span class="section-card-header-icon">🌐</span> 로컬라이제이션 — M.bytes</span>
            @if (Store.Localization != null)
            {
                <span class="badge badge-success">로드됨</span>
            }
        </div>
        <div class="section-card-body">
            <p class="text-sm text-dim" style="margin:0 0 10px">
                M.bytes를 로드하면 이벤트·아이템·유닛 편집 시 텍스트 미리보기가 활성화됩니다.
            </p>
            <InputFile OnChange="HandleMBytesUpload" style="color:var(--text);font-size:12px" />
            @if (Store.Localization != null)
            {
                var langs = Store.GetLanguageColumns();
                <div class="text-xs text-muted mt-1">
                    언어: @string.Join(" · ", langs)
                </div>
            }
        </div>
    </div>

    <!-- 사용 워크플로 -->
    <div class="section-card">
        <div class="section-card-header">
            <span><span class="section-card-header-icon">🔄</span> 사용 워크플로</span>
        </div>
        <div class="section-card-body">
            <div class="workflow-steps">
                <div class="workflow-step">
                    <div class="workflow-step-num">1</div>
                    <div class="workflow-step-label">Unity Export<br/><code style="font-size:9px">Tools › Hoheup</code></div>
                </div>
                <div class="workflow-step active">
                    <div class="workflow-step-num">2</div>
                    <div class="workflow-step-label">Import<br/>여기서 업로드</div>
                </div>
                <div class="workflow-step active">
                    <div class="workflow-step-num">3</div>
                    <div class="workflow-step-label">데이터 편집<br/>사이드바 선택</div>
                </div>
                <div class="workflow-step active">
                    <div class="workflow-step-num">4</div>
                    <div class="workflow-step-label">Export<br/>다운로드</div>
                </div>
                <div class="workflow-step">
                    <div class="workflow-step-num">5</div>
                    <div class="workflow-step-label">Unity Import<br/><code style="font-size:9px">Tools › Hoheup</code></div>
                </div>
            </div>
        </div>
    </div>

</div>
</div>

@code {
    string _msg = "";
    bool _isError;

    void SetMsg(string msg, bool err = false) { _msg = msg; _isError = err; }

    async Task HandleImport(InputFileChangeEventArgs e)
    {
        try
        {
            using var ms = new System.IO.MemoryStream();
            await e.File.OpenReadStream(10_000_000).CopyToAsync(ms);
            ExportSvc.Import(ms.ToArray());
            SetMsg($"불러오기 완료 ({e.File.Name}) — 이벤트 {Store.GameEvents.Count}, 아이템 {Store.GameItems.Count}");
        }
        catch (Exception ex) { SetMsg(ex.Message, true); }
    }

    async Task ExportDownload()
    {
        try
        {
            var bytes = ExportSvc.Export();
            var b64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadBytes", "EXPORTED.bytes", b64);
            SetMsg("다운로드 시작됨");
        }
        catch (Exception ex) { SetMsg(ex.Message, true); }
    }

    async Task HandleMBytesUpload(InputFileChangeEventArgs e)
    {
        try
        {
            using var ms = new System.IO.MemoryStream();
            await e.File.OpenReadStream(10_000_000).CopyToAsync(ms);
            string json = System.Text.Encoding.UTF8.GetString(ms.ToArray());
            Store.Localization = Newtonsoft.Json.JsonConvert
                .DeserializeObject<Dictionary<string, object>>(json);
            SetMsg("M.bytes 로드 완료 — 텍스트 미리보기 활성화됨");
        }
        catch (Exception ex) { SetMsg(ex.Message, true); }
    }
}
