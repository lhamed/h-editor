@page "/game-events"
@inject DataStore Store

<PageTitle>이벤트 — H-Editor</PageTitle>

<div class="page-layout">
    @{
        var filteredEvents = FilteredEvents().ToList();
    }

    <!-- ─── 이벤트 목록 ──────────────────────────────────────────────────── -->
    <div class="list-panel">
        <div class="list-panel-header">
            <span>이벤트 (@filteredEvents.Count / @Store.GameEvents.Count)</span>
            <button class="btn btn-success btn-sm" @onclick="CreateEvent">+ 새로 만들기</button>
        </div>
        <div class="list-search">
            <input type="search"
                   @bind="_eventSearch"
                   @bind:event="oninput"
                   placeholder="Key, 텍스트 키, 미리보기 검색" />
        </div>
        <div class="list-scroll">
            @if (filteredEvents.Count == 0)
            {
                <div class="list-empty">검색 결과가 없습니다</div>
            }
            @foreach (var evt in filteredEvents)
            {
                <div class="list-item @(_selected == evt ? "active" : "")"
                     @onclick="() => SelectEvent(evt)">
                    <div class="list-item-key">Key: @evt.Key</div>
                    <div class="list-item-name text-xs">블록 @evt.ContentBlocks.Count | 조건 @evt.Conditions.Count</div>
                    @{
                        var firstKey = evt.ContentBlocks.Count > 0 && evt.ContentBlocks[0].ContentItems.Count > 0
                            ? evt.ContentBlocks[0].ContentItems[0].TextKey : null;
                        var fl = Store.GetLanguageColumns().FirstOrDefault();
                        var preview = firstKey != null && fl != null ? Store.LookupText(firstKey, fl) : null;
                    }
                    @if (preview != null)
                    {
                        <div class="text-xs text-dim" style="overflow:hidden;max-height:28px">
                            @(preview.Length > 40 ? preview[..40] + "…" : preview)
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ─── 이벤트 편집 / 미리보기 ──────────────────────────────────────── -->
    @if (_selected == null)
    {
        <div class="empty-detail">이벤트를 선택하거나 새로 만드세요</div>
    }
    else
    {
        var evt = _selected;
        var langs = Store.GetLanguageColumns();
        <div class="event-workbench">
            <div class="event-preview-pane">
                <div class="unity-pane-title">
                    <span>Preview</span>
                    <span class="mono">Key @evt.Key</span>
                </div>
                @PreviewPanel(evt, langs)
            </div>

            <div class="detail-panel event-inspector-pane">

            <!-- 헤더 -->
            <div class="d-flex justify-between align-center" style="margin-bottom:12px">
                <div>
                    <div class="page-title" style="font-size:16px">Inspector</div>
                    <div class="text-xs text-dim">GameEvent 편집</div>
                </div>
                <button class="btn btn-danger btn-sm" @onclick="() => DeleteEvent(evt)">삭제</button>
            </div>

            <div class="inspector-jumpbar">
                <a class="btn btn-ghost btn-sm" href="#event-key">Key</a>
                <a class="btn btn-ghost btn-sm" href="#event-conditions">조건</a>
                <a class="btn btn-ghost btn-sm" href="#event-blocks">블록</a>
                <a class="btn btn-ghost btn-sm" href="#event-next">다음</a>
            </div>

                <!-- ── Key ─────────────────────────────────────────────────── -->
                <div class="section-card" id="event-key">
                    <div class="section-card-header">Key</div>
                    <div class="section-card-body">
                        <input type="number" min="900000"
                               value="@evt.Key"
                               @onchange="@(e => SetEvtKey(evt, e))"
                               class="@(Store.HasDuplicateEventKey(evt.Key, evt) ? "key-invalid" : evt.Key >= 900000 ? "key-valid" : "key-missing")" />
                        @if (Store.HasDuplicateEventKey(evt.Key, evt))
                        { <div class="text-danger text-xs mt-1">중복 Key 존재</div> }
                        @if (evt.Key < 900000)
                        { <div class="text-warning text-xs mt-1">Key는 900000 이상 권장</div> }
                    </div>
                </div>

                <!-- ── 발생 조건 ────────────────────────────────────────────── -->
                <div class="section-card" id="event-conditions">
                    <div class="section-card-header">
                        발생 조건 (@evt.Conditions.Count)개)
                        <button class="btn btn-secondary btn-sm"
                                @onclick="() => evt.Conditions.Add(new EventCondition())">+ 조건 추가</button>
                    </div>
                    <div class="section-card-body">
                        @if (evt.Conditions.Count == 0)
                        { <div class="text-dim text-sm">조건 없음 (항상 재생 가능)</div> }
                        @for (int ci = 0; ci < evt.Conditions.Count; ci++)
                        {
                            int cIdx = ci;
                            var cond = evt.Conditions[cIdx];
                            <div class="sub-item">
                                <div class="sub-item-header">
                                    <span>조건 #@(cIdx + 1)</span>
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => evt.Conditions.RemoveAt(cIdx)">×</button>
                                </div>
                                @ConditionEditor(cond)
                            </div>
                        }
                    </div>
                </div>

                <!-- ── 콘텐츠 블록 ─────────────────────────────────────────── -->
                <div class="section-card" id="event-blocks">
                    <div class="section-card-header">
                        콘텐츠 블록 (@evt.ContentBlocks.Count)개)
                        <button class="btn btn-success btn-sm"
                                @onclick="() => evt.ContentBlocks.Add(new EventContentBlock())">+ 블록 추가</button>
                    </div>
                    <div class="section-card-body">
                        @if (evt.ContentBlocks.Count == 0)
                        { <div class="alert alert-info">콘텐츠 블록이 없습니다.</div> }
                        @for (int bi = 0; bi < evt.ContentBlocks.Count; bi++)
                        {
                            int bIdx = bi;
                            var blockScope = "blocks";
                            var block = evt.ContentBlocks[bIdx];
                            var isCollapsed = IsBlockCollapsed(block);
                            <div class="@($"section-block sortable-item {(isCollapsed ? "collapsed" : "")} {SortableClass(blockScope, bIdx)}")" style="margin-bottom:12px"
                                 draggable="true"
                                 @ondragstart="() => StartDrag(blockScope, bIdx)"
                                 @ondragover:preventDefault
                                 @ondrop="() => DropOn(evt.ContentBlocks, blockScope, bIdx)"
                                 @ondragend="EndDrag">
                                <div class="section-block-title">
                                    <span class="drag-title">
                                        <span class="drag-handle" title="드래그해서 순서 변경">::</span> 블록 #@(bIdx + 1)
                                        <span class="block-summary">아이템 @block.ContentItems.Count · 효과 @block.CommonEffects.Count · 선택지 @block.Selections.Count</span>
                                    </span>
                                    <span class="item-actions">
                                        <button class="btn btn-ghost btn-sm" @onclick="() => ToggleBlockCollapsed(block)">@(isCollapsed ? "펼치기" : "접기")</button>
                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 위로" disabled="@(bIdx == 0)" @onclick="() => MoveItem(evt.ContentBlocks, bIdx, 0)">⇤</button>
                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(bIdx == 0)" @onclick="() => MoveItem(evt.ContentBlocks, bIdx, bIdx - 1)">↑</button>
                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(bIdx >= evt.ContentBlocks.Count - 1)" @onclick="() => MoveItem(evt.ContentBlocks, bIdx, bIdx + 1)">↓</button>
                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 아래로" disabled="@(bIdx >= evt.ContentBlocks.Count - 1)" @onclick="() => MoveItem(evt.ContentBlocks, bIdx, evt.ContentBlocks.Count - 1)">⇥</button>
                                        <button class="btn btn-danger btn-sm"
                                                @onclick="() => evt.ContentBlocks.RemoveAt(bIdx)">블록 삭제</button>
                                    </span>
                                </div>

                                @if (isCollapsed)
                                {
                                    <div class="collapsed-block-summary">
                                        @BlockPreviewText(block)
                                    </div>
                                }
                                else
                                {
                                    <!-- 콘텐츠 아이템 -->
                                    <div style="margin-bottom:10px">
                                        <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                            <span class="text-xs text-dim" style="font-weight:700">콘텐츠 아이템 (@block.ContentItems.Count)</span>
                                            <button class="btn btn-secondary btn-sm"
                                                    @onclick="() => block.ContentItems.Add(new EventContentItem())">+ 아이템 추가</button>
                                        </div>
                                        @for (int ii = 0; ii < block.ContentItems.Count; ii++)
                                        {
                                            int iIdx = ii;
                                            var itemScope = $"block:{bIdx}:items";
                                            var item = block.ContentItems[iIdx];
                                            <div class="@($"sub-item sortable-item {SortableClass(itemScope, iIdx)}")" style="background:var(--subtle-bg)"
                                                 draggable="true"
                                                 @ondragstart="() => StartDrag(itemScope, iIdx)"
                                                 @ondragover:preventDefault
                                                 @ondrop="() => DropOn(block.ContentItems, itemScope, iIdx)"
                                                 @ondragend="EndDrag">
                                                <div class="sub-item-header">
                                                    <span class="drag-title"><span class="drag-handle" title="드래그해서 순서 변경">::</span> 아이템 #@(iIdx+1)
                                                        <span class="badge @(item.Type == ContentItemType.Dialogue ? "badge-info" : item.Type == ContentItemType.Image ? "badge-warning" : "badge-success")">@item.Type</span>
                                                    </span>
                                                    <span class="item-actions">
                                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 위로" disabled="@(iIdx == 0)" @onclick="() => MoveItem(block.ContentItems, iIdx, 0)">⇤</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(iIdx == 0)" @onclick="() => MoveItem(block.ContentItems, iIdx, iIdx - 1)">↑</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(iIdx >= block.ContentItems.Count - 1)" @onclick="() => MoveItem(block.ContentItems, iIdx, iIdx + 1)">↓</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 아래로" disabled="@(iIdx >= block.ContentItems.Count - 1)" @onclick="() => MoveItem(block.ContentItems, iIdx, block.ContentItems.Count - 1)">⇥</button>
                                                        <button class="btn btn-danger btn-sm"
                                                                @onclick="() => block.ContentItems.RemoveAt(iIdx)">×</button>
                                                    </span>
                                                </div>
                                                <div class="form-group">
                                                    <label>Type</label>
                                                    <select value="@item.Type" @onchange="@(e => SetContentItemType(item, e))">
                                                        <option value="Content">Content (일반 텍스트)</option>
                                                        <option value="Dialogue">Dialogue (대사)</option>
                                                        <option value="Image">Image (이미지)</option>
                                                        <option value="Flush">Flush (출력 밀어내기)</option>
                                                    </select>
                                                </div>
                                                @if (item.Type != ContentItemType.Image && item.Type != ContentItemType.Flush)
                                                {
                                                    <div class="form-group">
                                                        <label>TextKey</label>
                                                        <input type="text" @bind="item.TextKey" placeholder="evt.text.xxx" />
                                                        @foreach (var lang in langs)
                                                        {
                                                            var t = Store.LookupText(item.TextKey, lang);
                                                            <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{item.TextKey}' 없음")</div>
                                                        }
                                                    </div>
                                                }
                                                @if (item.Type == ContentItemType.Image)
                                                {
                                                    <div class="form-group">
                                                        <label>Image (스프라이트 에셋 경로)</label>
                                                        <input type="text" @bind="item.ImagePath"
                                                               placeholder="Assets/Project/Contents/UI/..." />
                                                        @if (!string.IsNullOrEmpty(item.ImagePath))
                                                        {
                                                            <div class="text-xs text-dim" style="margin-top:3px">
                                                                Unity 임포트 시 이 경로로 Sprite를 로드합니다.
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                @if (item.Type == ContentItemType.Dialogue)
                                                {
                                                    <div class="form-group">
                                                        <label>SpeakerNameKey</label>
                                                        <input type="text" @bind="item.SpeakerNameKey" placeholder="npc.name.xxx" />
                                                        @foreach (var lang in langs)
                                                        {
                                                            var t = Store.LookupText(item.SpeakerNameKey, lang);
                                                            <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{item.SpeakerNameKey}' 없음")</div>
                                                        }
                                                    </div>
                                                    <div class="form-group">
                                                        <label>Expression (스프라이트 에셋 경로)</label>
                                                        <input type="text" @bind="item.ExpressionPath"
                                                               placeholder="Assets/Project/Contents/UI/FACES.png" />
                                                        @if (!string.IsNullOrEmpty(item.ExpressionPath))
                                                        {
                                                            <div class="text-xs text-dim" style="margin-top:3px">
                                                                Unity 임포트 시 이 경로로 Sprite를 로드합니다.
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                @if (item.Type != ContentItemType.Flush)
                                                {
                                                    {
                                                        item.UIEffect ??= new EventUIEffectSettings();
                                                    }
                                                    @UIEffectEditor("콘텐츠 UI 이펙트", item.UIEffect, panelOptions: true, buttonOptions: false)
                                                }
                                            </div>
                                        }
                                    </div>

                                    <!-- 공통 효과 -->
                                    <div style="margin-bottom:10px">
                                        <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                            <span class="text-xs text-dim" style="font-weight:700">공통 효과 (@block.CommonEffects.Count)</span>
                                            <button class="btn btn-secondary btn-sm"
                                                    @onclick="() => block.CommonEffects.Add(new EventEffect())">+ 효과 추가</button>
                                        </div>
                                        @for (int ei = 0; ei < block.CommonEffects.Count; ei++)
                                        {
                                            int eIdx = ei;
                                            var effectScope = $"block:{bIdx}:effects";
                                            var eff = block.CommonEffects[eIdx];
                                            <div class="@($"sub-item sortable-item {SortableClass(effectScope, eIdx)}")" style="background:var(--subtle-bg)"
                                                 draggable="true"
                                                 @ondragstart="() => StartDrag(effectScope, eIdx)"
                                                 @ondragover:preventDefault
                                                 @ondrop="() => DropOn(block.CommonEffects, effectScope, eIdx)"
                                                 @ondragend="EndDrag">
                                                <div class="sub-item-header">
                                                    <span class="drag-title"><span class="drag-handle" title="드래그해서 순서 변경">::</span> 효과 #@(eIdx+1)</span>
                                                    <span class="item-actions">
                                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 위로" disabled="@(eIdx == 0)" @onclick="() => MoveItem(block.CommonEffects, eIdx, 0)">⇤</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(eIdx == 0)" @onclick="() => MoveItem(block.CommonEffects, eIdx, eIdx - 1)">↑</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(eIdx >= block.CommonEffects.Count - 1)" @onclick="() => MoveItem(block.CommonEffects, eIdx, eIdx + 1)">↓</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 아래로" disabled="@(eIdx >= block.CommonEffects.Count - 1)" @onclick="() => MoveItem(block.CommonEffects, eIdx, block.CommonEffects.Count - 1)">⇥</button>
                                                        <button class="btn btn-danger btn-sm"
                                                                @onclick="() => block.CommonEffects.RemoveAt(eIdx)">×</button>
                                                    </span>
                                                </div>
                                                @EffectEditor(eff)
                                            </div>
                                        }
                                    </div>

                                    <!-- 선택지 -->
                                    <div>
                                        <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                            <span class="text-xs text-dim" style="font-weight:700">선택지 (@block.Selections.Count)</span>
                                            <button class="btn btn-secondary btn-sm"
                                                    @onclick="() => block.Selections.Add(new EventSelection())">+ 선택지 추가</button>
                                        </div>
                                        @for (int si = 0; si < block.Selections.Count; si++)
                                        {
                                            int sIdx = si;
                                            var selectionScope = $"block:{bIdx}:selections";
                                            var sel = block.Selections[sIdx];
                                            <div class="@($"sub-item sortable-item {SortableClass(selectionScope, sIdx)}")"
                                                 draggable="true"
                                                 @ondragstart="() => StartDrag(selectionScope, sIdx)"
                                                 @ondragover:preventDefault
                                                 @ondrop="() => DropOn(block.Selections, selectionScope, sIdx)"
                                                 @ondragend="EndDrag">
                                                <div class="sub-item-header">
                                                    <span class="drag-title"><span class="drag-handle" title="드래그해서 순서 변경">::</span> 선택지 #@(sIdx+1)</span>
                                                    <span class="item-actions">
                                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 위로" disabled="@(sIdx == 0)" @onclick="() => MoveItem(block.Selections, sIdx, 0)">⇤</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(sIdx == 0)" @onclick="() => MoveItem(block.Selections, sIdx, sIdx - 1)">↑</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(sIdx >= block.Selections.Count - 1)" @onclick="() => MoveItem(block.Selections, sIdx, sIdx + 1)">↓</button>
                                                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 아래로" disabled="@(sIdx >= block.Selections.Count - 1)" @onclick="() => MoveItem(block.Selections, sIdx, block.Selections.Count - 1)">⇥</button>
                                                        <button class="btn btn-danger btn-sm"
                                                                @onclick="() => block.Selections.RemoveAt(sIdx)">×</button>
                                                    </span>
                                                </div>
                                                <div class="form-group">
                                                    <label>SelectionTextKey</label>
                                                    <input type="text" @bind="sel.SelectionTextKey" placeholder="evt.sel.xxx" />
                                                    @foreach (var lang in langs)
                                                    {
                                                        var t = Store.LookupText(sel.SelectionTextKey, lang);
                                                        <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{sel.SelectionTextKey}' 없음")</div>
                                                    }
                                                </div>
                                                <div class="form-group">
                                                    <label>ResultTextKey</label>
                                                    <input type="text" @bind="sel.ResultTextKey" placeholder="evt.res.xxx" />
                                                    @foreach (var lang in langs)
                                                    {
                                                        var t = Store.LookupText(sel.ResultTextKey, lang);
                                                        <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{sel.ResultTextKey}' 없음")</div>
                                                    }
                                                </div>
                                                <!-- 선택지 효과 -->
                                                <div style="margin-top:8px">
                                                    <div class="d-flex justify-between align-center" style="margin-bottom:4px">
                                                        <span class="text-xs text-dim">선택지 효과 (@sel.Effects.Count)</span>
                                                        <button class="btn btn-secondary btn-sm"
                                                                @onclick="() => sel.Effects.Add(new EventEffect())">+ 효과</button>
                                                    </div>
                                                    @for (int sei = 0; sei < sel.Effects.Count; sei++)
                                                    {
                                                        int seIdx = sei;
                                                        var selectionEffectScope = $"block:{bIdx}:selection:{sIdx}:effects";
                                                        var seff = sel.Effects[seIdx];
                                                        <div class="@($"sub-item sortable-item {SortableClass(selectionEffectScope, seIdx)}")" style="background:var(--subtle-bg)"
                                                             draggable="true"
                                                             @ondragstart="() => StartDrag(selectionEffectScope, seIdx)"
                                                             @ondragover:preventDefault
                                                             @ondrop="() => DropOn(sel.Effects, selectionEffectScope, seIdx)"
                                                             @ondragend="EndDrag">
                                                            <div class="sub-item-header">
                                                                <span class="drag-title"><span class="drag-handle" title="드래그해서 순서 변경">::</span> 효과 #@(seIdx+1)</span>
                                                                <span class="item-actions">
                                                                    <button class="btn btn-ghost btn-sm btn-icon" title="맨 위로" disabled="@(seIdx == 0)" @onclick="() => MoveItem(sel.Effects, seIdx, 0)">⇤</button>
                                                                    <button class="btn btn-ghost btn-sm btn-icon" disabled="@(seIdx == 0)" @onclick="() => MoveItem(sel.Effects, seIdx, seIdx - 1)">↑</button>
                                                                    <button class="btn btn-ghost btn-sm btn-icon" disabled="@(seIdx >= sel.Effects.Count - 1)" @onclick="() => MoveItem(sel.Effects, seIdx, seIdx + 1)">↓</button>
                                                                    <button class="btn btn-ghost btn-sm btn-icon" title="맨 아래로" disabled="@(seIdx >= sel.Effects.Count - 1)" @onclick="() => MoveItem(sel.Effects, seIdx, sel.Effects.Count - 1)">⇥</button>
                                                                    <button class="btn btn-danger btn-sm"
                                                                            @onclick="() => sel.Effects.RemoveAt(seIdx)">×</button>
                                                                </span>
                                                            </div>
                                                            @EffectEditor(seff)
                                                        </div>
                                                    }
                                                </div>
                                                @BranchBlocksEditor(sel, langs, 1)
                                                <!-- 배틀 연결 -->
                                                <div class="inline-row" style="margin-top:8px">
                                                    <div class="form-group">
                                                        <label>승리 후 이벤트 Key</label>
                                                        <input type="number"
                                                               value="@sel.BattleVictoryEventKey"
                                                               @onchange="@(e => SetSelVictoryKey(sel, e))" />
                                                    </div>
                                                    <div class="form-group">
                                                        <label>패배 후 이벤트 Key</label>
                                                        <input type="number"
                                                               value="@sel.BattleDefeatEventKey"
                                                               @onchange="@(e => SetSelDefeatKey(sel, e))" />
                                                    </div>
                                                </div>
                                                @{
                                                    sel.UIEffect ??= new EventUIEffectSettings();
                                                }
                                                @UIEffectEditor("선택지 UI 이펙트", sel.UIEffect, panelOptions: false, buttonOptions: true)
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- ── 다음 이벤트 ──────────────────────────────────────────── -->
                <div class="section-card" id="event-next">
                    <div class="section-card-header">다음 이벤트</div>
                    <div class="section-card-body">
                        <div class="form-group">
                            <label>NextEventMode</label>
                            <select value="@evt.NextEventMode" @onchange="@(e => SetNextMode(evt, e))">
                                <option value="Specific">Specific — 순서대로 조건 통과한 첫 번째</option>
                                <option value="Conditional">Conditional — 조건부 엔트리 평가</option>
                                <option value="Random">Random — 조건 통과 중 랜덤</option>
                            </select>
                        </div>

                        @if (evt.NextEventMode != NextEventMode.Conditional)
                        {
                            <div>
                                <div class="d-flex justify-between align-center" style="margin-bottom:6px">
