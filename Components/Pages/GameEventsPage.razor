                                </div>
                                @for (int ni = 0; ni < evt.NextEventEntries.Count; ni++)
                                {
                                    int nIdx = ni;
                                    var entry = evt.NextEventEntries[nIdx];
                                    <div class="sub-item">
                                        <div class="sub-item-header">
                                            <span>엔트리 #@(nIdx+1)</span>
                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => evt.NextEventEntries.RemoveAt(nIdx)">×</button>
                                        </div>
                                        <div class="form-group">
                                            <label>목표 이벤트 Key</label>
                                            <select value="@entry.EventKey"
                                                    @onchange="@(e => SetEntryKey(entry, e))">
                                                <option value="0">(이벤트 선택)</option>
                                                @foreach (var e2 in Store.GameEvents.OrderBy(e => e.Key))
                                                {
                                                    <option value="@e2.Key">Key @e2.Key</option>
                                                }
                                            </select>
                                        </div>
                                        <div>
                                            <div class="d-flex justify-between align-center" style="margin-bottom:4px">
                                                <span class="text-xs text-dim">조건 (@entry.Conditions.Count)</span>
                                                <button class="btn btn-secondary btn-sm"
                                                        @onclick="() => entry.Conditions.Add(new EventCondition())">+ 조건</button>
                                            </div>
                                            @for (int eci = 0; eci < entry.Conditions.Count; eci++)
                                            {
                                                int ecIdx = eci;
                                                var cond = entry.Conditions[ecIdx];
                                                <div class="sub-item" style="background:var(--subtle-bg)">
                                                    <div class="sub-item-header">
                                                        <span>조건 #@(ecIdx+1)</span>
                                                        <button class="btn btn-danger btn-sm"
                                                                @onclick="() => entry.Conditions.RemoveAt(ecIdx)">×</button>
                                                    </div>
                                                    @ConditionEditor(cond)
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    GameEventData? _selected;
    int _previewBlockIdx;
    string _previewLang = "";
    string _eventSearch = "";
    DragState? _dragState;
    readonly HashSet<EventContentBlock> _collapsedBlocks = new();

    sealed record DragState(string Scope, int FromIndex);

    // ─── CRUD ──────────────────────────────────────────────────────────────

    void SelectEvent(GameEventData evt)
    {
        _selected = evt;
        _previewBlockIdx = 0;
    }

    void CreateEvent()
    {
        long nextKey = Store.GameEvents.Count > 0
            ? Math.Max(900000L, Store.GameEvents.Max(e => e.Key) + 1)
            : 900000L;
        var evt = new GameEventData
        {
            Key = nextKey,
            ContentBlocks = new() { new EventContentBlock() }
        };
        Store.GameEvents.Add(evt);
        SelectEvent(evt);
    }

    void DeleteEvent(GameEventData evt)
    {
        Store.GameEvents.Remove(evt);
        if (_selected == evt) _selected = null;
        _collapsedBlocks.Clear();
    }

    bool IsBlockCollapsed(EventContentBlock block)
        => _collapsedBlocks.Contains(block);

    void ToggleBlockCollapsed(EventContentBlock block)
    {
        if (!_collapsedBlocks.Add(block))
            _collapsedBlocks.Remove(block);
    }

    string BlockPreviewText(EventContentBlock block)
    {
        var firstText = block.ContentItems
            .Select(i => i.Type == ContentItemType.Image ? i.ImagePath : i.TextKey)
            .FirstOrDefault(v => !string.IsNullOrWhiteSpace(v));

        if (!string.IsNullOrWhiteSpace(firstText))
            return firstText;

        if (block.Selections.Count > 0)
            return $"선택지 {block.Selections.Count}개";

        if (block.CommonEffects.Count > 0)
            return $"효과 {block.CommonEffects.Count}개";

        return "비어 있는 블록";
    }

    IEnumerable<GameEventData> FilteredEvents()
    {
        var query = _eventSearch.Trim();
        var events = Store.GameEvents.OrderBy(e => e.Key);
        if (string.IsNullOrWhiteSpace(query))
            return events;

        var lang = Store.GetLanguageColumns().FirstOrDefault();
        return events.Where(evt => EventMatchesSearch(evt, query, lang));
    }

    bool EventMatchesSearch(GameEventData evt, string query, string? lang)
    {
        if (evt.Key.ToString().Contains(query, StringComparison.OrdinalIgnoreCase))
            return true;

        foreach (var key in EventSearchKeys(evt.ContentBlocks))
        {
            if (!string.IsNullOrWhiteSpace(key) &&
                key.Contains(query, StringComparison.OrdinalIgnoreCase))
                return true;

            if (!string.IsNullOrWhiteSpace(lang))
            {
                var text = Store.LookupText(key, lang);
                if (!string.IsNullOrWhiteSpace(text) &&
                    text.Contains(query, StringComparison.OrdinalIgnoreCase))
                    return true;
            }
        }

        return false;
    }

    IEnumerable<string> EventSearchKeys(IEnumerable<EventContentBlock> blocks)
    {
        foreach (var block in blocks)
        {
            foreach (var item in block.ContentItems)
            {
                if (!string.IsNullOrWhiteSpace(item.TextKey)) yield return item.TextKey;
                if (!string.IsNullOrWhiteSpace(item.SpeakerNameKey)) yield return item.SpeakerNameKey;
            }

            foreach (var sel in block.Selections)
            {
                if (!string.IsNullOrWhiteSpace(sel.SelectionTextKey)) yield return sel.SelectionTextKey;
                if (!string.IsNullOrWhiteSpace(sel.ResultTextKey)) yield return sel.ResultTextKey;

                foreach (var nestedKey in EventSearchKeys(sel.BranchBlocks))
                    yield return nestedKey;
            }
        }
    }

    // ─── 순서 변경 ───────────────────────────────────────────────────────────

    void StartDrag(string scope, int fromIndex)
    {
        _dragState = new DragState(scope, fromIndex);
    }

    void EndDrag()
    {
        _dragState = null;
    }

    string SortableClass(string scope, int index)
    {
        if (_dragState is null || _dragState.Scope != scope)
            return "";

        return _dragState.FromIndex == index ? "dragging" : "drop-target";
    }

    void DropOn<T>(IList<T> items, string scope, int toIndex)
    {
        if (_dragState is null || _dragState.Scope != scope)
            return;

        MoveItem(items, _dragState.FromIndex, toIndex);
        _dragState = null;
    }

    void MoveItem<T>(IList<T> items, int fromIndex, int toIndex)
    {
        if (fromIndex == toIndex ||
            fromIndex < 0 || fromIndex >= items.Count ||
            toIndex < 0 || toIndex >= items.Count)
            return;

        var item = items[fromIndex];
        items.RemoveAt(fromIndex);
        items.Insert(toIndex, item);

        if (_selected != null && ReferenceEquals(items, _selected.ContentBlocks))
            SyncPreviewBlockAfterMove(fromIndex, toIndex);
    }

    void SyncPreviewBlockAfterMove(int fromIndex, int toIndex)
    {
        if (_previewBlockIdx == fromIndex)
            _previewBlockIdx = toIndex;
        else if (fromIndex < _previewBlockIdx && toIndex >= _previewBlockIdx)
            _previewBlockIdx--;
        else if (fromIndex > _previewBlockIdx && toIndex <= _previewBlockIdx)
            _previewBlockIdx++;
    }

    // ─── 필드 세터 ──────────────────────────────────────────────────────────

    void SetEvtKey(GameEventData evt, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) evt.Key = v; }

    void SetNextMode(GameEventData evt, ChangeEventArgs e)
    { if (Enum.TryParse<NextEventMode>(e.Value?.ToString(), out var v)) evt.NextEventMode = v; }

    void SetNextKey(GameEventData evt, int idx, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) evt.NextEventKeys[idx] = v; }

    void SetEntryKey(NextEventEntry entry, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) entry.EventKey = v; }

    void SetContentItemType(EventContentItem item, ChangeEventArgs e)
    { if (Enum.TryParse<ContentItemType>(e.Value?.ToString(), out var v)) item.Type = v; }

    void SetSelVictoryKey(EventSelection sel, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) sel.BattleVictoryEventKey = v; }

    void SetSelDefeatKey(EventSelection sel, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) sel.BattleDefeatEventKey = v; }

    RenderFragment BranchBlocksEditor(EventSelection sel, List<string> langs, int depth) =>
	    @<div style="margin-top:8px">
        <div class="d-flex justify-between align-center" style="margin-bottom:4px">
            <span class="text-xs text-dim">중첩 분기 블록 (@sel.BranchBlocks.Count)</span>
            <button class="btn btn-secondary btn-sm"
                    @onclick="() => sel.BranchBlocks.Add(new EventContentBlock())">+ 분기 블록</button>
        </div>
	        @for (int bi = 0; bi < sel.BranchBlocks.Count; bi++)
	        {
	            int bIdx = bi;
	            var branchScope = $"selection:{sel.GetHashCode()}:branches";
	            var branchBlock = sel.BranchBlocks[bIdx];
	            <div class="@($"sub-item sortable-item {SortableClass(branchScope, bIdx)}")" style="background:var(--subtle-bg);border-left:3px solid var(--accent);margin-left:@(Math.Min(depth, 4) * 10)px"
	                 draggable="true"
	                 @ondragstart="() => StartDrag(branchScope, bIdx)"
	                 @ondragover:preventDefault
	                 @ondrop="() => DropOn(sel.BranchBlocks, branchScope, bIdx)"
	                 @ondragend="EndDrag">
	                <div class="sub-item-header">
	                    <span class="drag-title"><span class="drag-handle" title="드래그해서 순서 변경">::</span> 분기 블록 #@(bIdx + 1)</span>
	                    <span class="item-actions">
	                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 위로" disabled="@(bIdx == 0)" @onclick="() => MoveItem(sel.BranchBlocks, bIdx, 0)">⇤</button>
	                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(bIdx == 0)" @onclick="() => MoveItem(sel.BranchBlocks, bIdx, bIdx - 1)">↑</button>
	                        <button class="btn btn-ghost btn-sm btn-icon" disabled="@(bIdx >= sel.BranchBlocks.Count - 1)" @onclick="() => MoveItem(sel.BranchBlocks, bIdx, bIdx + 1)">↓</button>
	                        <button class="btn btn-ghost btn-sm btn-icon" title="맨 아래로" disabled="@(bIdx >= sel.BranchBlocks.Count - 1)" @onclick="() => MoveItem(sel.BranchBlocks, bIdx, sel.BranchBlocks.Count - 1)">⇥</button>
	                        <button class="btn btn-danger btn-sm"
	                                @onclick="() => sel.BranchBlocks.RemoveAt(bIdx)">×</button>
	                    </span>
	                </div>
                @ContentBlockEditor(branchBlock, langs, depth)
