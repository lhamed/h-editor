@page "/game-events"
@inject DataStore Store

<PageTitle>이벤트 — H-Editor</PageTitle>

<div class="page-layout">
    <!-- ─── 이벤트 목록 ──────────────────────────────────────────────────── -->
    <div class="list-panel">
        <div class="list-panel-header">
            <span>이벤트 (@Store.GameEvents.Count)</span>
            <button class="btn btn-success btn-sm" @onclick="CreateEvent">+ 새로 만들기</button>
        </div>
        <div class="list-scroll">
            @foreach (var evt in Store.GameEvents.OrderBy(e => e.Key))
            {
                <div class="list-item @(_selected == evt ? "active" : "")"
                     @onclick="() => _selected = evt">
                    <div class="list-item-key">Key: @evt.Key</div>
                    <div class="list-item-name text-xs">블록 @evt.ContentBlocks.Count | 조건 @evt.Conditions.Count</div>
                    @{
                        var firstKey = evt.ContentBlocks.Count > 0 && evt.ContentBlocks[0].ContentItems.Count > 0
                            ? evt.ContentBlocks[0].ContentItems[0].TextKey : null;
                        var fl = Store.GetLanguageColumns().FirstOrDefault();
                        var preview = firstKey != null && fl != null ? Store.LookupText(firstKey, fl) : null;
                    }
                    @if (preview != null)
                    {
                        <div class="text-xs text-dim" style="overflow:hidden;max-height:28px">
                            @(preview.Length > 40 ? preview[..40] + "…" : preview)
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ─── 이벤트 편집 ──────────────────────────────────────────────────── -->
    @if (_selected == null)
    {
        <div class="empty-detail">이벤트를 선택하거나 새로 만드세요</div>
    }
    else
    {
        var evt = _selected;
        var langs = Store.GetLanguageColumns();
        <div class="detail-panel">
            <div class="d-flex justify-between align-center" style="margin-bottom:16px">
                <div>
                    <div class="page-title" style="font-size:16px">GameEvent 편집</div>
                    <div class="text-xs text-dim">Key @evt.Key</div>
                </div>
                <button class="btn btn-danger btn-sm" @onclick="() => DeleteEvent(evt)">삭제</button>
            </div>

            <!-- ── Key ────────────────────────────────────────────────────── -->
            <div class="section-card">
                <div class="section-card-header">Key</div>
                <div class="section-card-body">
                    <input type="number" min="900000"
                           value="@evt.Key"
                           @onchange="@(e => SetEvtKey(evt, e))"
                           class="@(Store.HasDuplicateEventKey(evt.Key, evt) ? "key-invalid" : evt.Key >= 900000 ? "key-valid" : "key-missing")" />
                    @if (Store.HasDuplicateEventKey(evt.Key, evt))
                    { <div class="text-danger text-xs mt-1">중복 Key 존재</div> }
                    @if (evt.Key < 900000)
                    { <div class="text-warning text-xs mt-1">Key는 900000 이상 권장</div> }
                </div>
            </div>

            <!-- ── 발생 조건 ───────────────────────────────────────────────── -->
            <div class="section-card">
                <div class="section-card-header">
                    발생 조건 (@evt.Conditions.Count)개)
                    <button class="btn btn-secondary btn-sm"
                            @onclick="() => evt.Conditions.Add(new EventCondition())">+ 조건 추가</button>
                </div>
                <div class="section-card-body">
                    @if (evt.Conditions.Count == 0)
                    { <div class="text-dim text-sm">조건 없음 (항상 재생 가능)</div> }
                    @for (int ci = 0; ci < evt.Conditions.Count; ci++)
                    {
                        int cIdx = ci;
                        var cond = evt.Conditions[cIdx];
                        <div class="sub-item">
                            <div class="sub-item-header">
                                <span>조건 #@(cIdx + 1)</span>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => evt.Conditions.RemoveAt(cIdx)">×</button>
                            </div>
                            @ConditionEditor(cond)
                        </div>
                    }
                </div>
            </div>

            <!-- ── 콘텐츠 블록 ────────────────────────────────────────────── -->
            <div class="section-card">
                <div class="section-card-header">
                    콘텐츠 블록 (@evt.ContentBlocks.Count)개)
                    <button class="btn btn-success btn-sm"
                            @onclick="() => evt.ContentBlocks.Add(new EventContentBlock())">+ 블록 추가</button>
                </div>
                <div class="section-card-body">
                    @if (evt.ContentBlocks.Count == 0)
                    { <div class="alert alert-info">콘텐츠 블록이 없습니다.</div> }
                    @for (int bi = 0; bi < evt.ContentBlocks.Count; bi++)
                    {
                        int bIdx = bi;
                        var block = evt.ContentBlocks[bIdx];
                        <div class="section-block" style="margin-bottom:12px">
                            <div class="section-block-title">
                                블록 #@(bIdx + 1)
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => evt.ContentBlocks.RemoveAt(bIdx)">블록 삭제</button>
                            </div>

                            <!-- 콘텐츠 아이템 -->
                            <div style="margin-bottom:10px">
                                <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                    <span class="text-xs text-dim" style="font-weight:700">콘텐츠 아이템 (@block.ContentItems.Count)</span>
                                    <button class="btn btn-secondary btn-sm"
                                            @onclick="() => block.ContentItems.Add(new EventContentItem())">+ 아이템 추가</button>
                                </div>
                                @for (int ii = 0; ii < block.ContentItems.Count; ii++)
                                {
                                    int iIdx = ii;
                                    var item = block.ContentItems[iIdx];
                                    <div class="sub-item" style="background:rgba(0,0,0,0.15)">
                                        <div class="sub-item-header">
                                            <span>아이템 #@(iIdx+1)
                                                <span class="badge @(item.Type == ContentItemType.Dialogue ? "badge-info" : "badge-success")">@item.Type</span>
                                            </span>
                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => block.ContentItems.RemoveAt(iIdx)">×</button>
                                        </div>
                                        <div class="form-group">
                                            <label>Type</label>
                                            <select value="@item.Type" @onchange="@(e => SetContentItemType(item, e))">
                                                <option value="Content">Content (일반 텍스트)</option>
                                                <option value="Dialogue">Dialogue (대사)</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>TextKey</label>
                                            <input type="text" @bind="item.TextKey" placeholder="evt.text.xxx" />
                                            @foreach (var lang in langs)
                                            {
                                                var t = Store.LookupText(item.TextKey, lang);
                                                <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{item.TextKey}' 없음")</div>
                                            }
                                        </div>
                                        @if (item.Type == ContentItemType.Dialogue)
                                        {
                                            <div class="form-group">
                                                <label>SpeakerNameKey</label>
                                                <input type="text" @bind="item.SpeakerNameKey" placeholder="npc.name.xxx" />
                                                @foreach (var lang in langs)
                                                {
                                                    var t = Store.LookupText(item.SpeakerNameKey, lang);
                                                    <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{item.SpeakerNameKey}' 없음")</div>
                                                }
                                            </div>
                                            <div class="form-group">
                                                <label>Expression (스프라이트 에셋 경로)</label>
                                                <input type="text" @bind="item.ExpressionPath"
                                                       placeholder="Assets/Project/Contents/UI/FACES.png" />
                                                @if (!string.IsNullOrEmpty(item.ExpressionPath))
                                                {
                                                    <div class="text-xs text-dim" style="margin-top:3px">
                                                        Unity 임포트 시 이 경로로 Sprite를 로드합니다.
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- 공통 효과 -->
                            <div style="margin-bottom:10px">
                                <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                    <span class="text-xs text-dim" style="font-weight:700">공통 효과 (@block.CommonEffects.Count)</span>
                                    <button class="btn btn-secondary btn-sm"
                                            @onclick="() => block.CommonEffects.Add(new EventEffect())">+ 효과 추가</button>
                                </div>
                                @for (int ei = 0; ei < block.CommonEffects.Count; ei++)
                                {
                                    int eIdx = ei;
                                    var eff = block.CommonEffects[eIdx];
                                    <div class="sub-item" style="background:rgba(0,0,0,0.15)">
                                        <div class="sub-item-header">
                                            <span>효과 #@(eIdx+1)</span>
                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => block.CommonEffects.RemoveAt(eIdx)">×</button>
                                        </div>
                                        @EffectEditor(eff)
                                    </div>
                                }
                            </div>

                            <!-- 선택지 -->
                            <div>
                                <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                    <span class="text-xs text-dim" style="font-weight:700">선택지 (@block.Selections.Count)</span>
                                    <button class="btn btn-secondary btn-sm"
                                            @onclick="() => block.Selections.Add(new EventSelection())">+ 선택지 추가</button>
                                </div>
                                @for (int si = 0; si < block.Selections.Count; si++)
                                {
                                    int sIdx = si;
                                    var sel = block.Selections[sIdx];
                                    <div class="sub-item">
                                        <div class="sub-item-header">
                                            <span>선택지 #@(sIdx+1)</span>
                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="() => block.Selections.RemoveAt(sIdx)">×</button>
                                        </div>
                                        <div class="form-group">
                                            <label>SelectionTextKey</label>
                                            <input type="text" @bind="sel.SelectionTextKey" placeholder="evt.sel.xxx" />
                                            @foreach (var lang in langs)
                                            {
                                                var t = Store.LookupText(sel.SelectionTextKey, lang);
                                                <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{sel.SelectionTextKey}' 없음")</div>
                                            }
                                        </div>
                                        <div class="form-group">
                                            <label>ResultTextKey</label>
                                            <input type="text" @bind="sel.ResultTextKey" placeholder="evt.res.xxx" />
                                            @foreach (var lang in langs)
                                            {
                                                var t = Store.LookupText(sel.ResultTextKey, lang);
                                                <div class="text-preview @(t != null ? "found" : "missing")">[@lang] @(t ?? $"키 '{sel.ResultTextKey}' 없음")</div>
                                            }
                                        </div>
                                        <!-- 선택지 효과 -->
                                        <div style="margin-top:8px">
                                            <div class="d-flex justify-between align-center" style="margin-bottom:4px">
                                                <span class="text-xs text-dim">선택지 효과 (@sel.Effects.Count)</span>
                                                <button class="btn btn-secondary btn-sm"
                                                        @onclick="() => sel.Effects.Add(new EventEffect())">+ 효과</button>
                                            </div>
                                            @for (int sei = 0; sei < sel.Effects.Count; sei++)
                                            {
                                                int seIdx = sei;
                                                var seff = sel.Effects[seIdx];
                                                <div class="sub-item" style="background:rgba(0,0,0,0.2)">
                                                    <div class="sub-item-header">
                                                        <span>효과 #@(seIdx+1)</span>
                                                        <button class="btn btn-danger btn-sm"
                                                                @onclick="() => sel.Effects.RemoveAt(seIdx)">×</button>
                                                    </div>
                                                    @EffectEditor(seff)
                                                </div>
                                            }
                                        </div>
                                        <!-- 배틀 연결 -->
                                        <div class="inline-row" style="margin-top:8px">
                                            <div class="form-group">
                                                <label>승리 후 이벤트 Key</label>
                                                <input type="number"
                                                       value="@sel.BattleVictoryEventKey"
                                                       @onchange="@(e => SetSelVictoryKey(sel, e))" />
                                            </div>
                                            <div class="form-group">
                                                <label>패배 후 이벤트 Key</label>
                                                <input type="number"
                                                       value="@sel.BattleDefeatEventKey"
                                                       @onchange="@(e => SetSelDefeatKey(sel, e))" />
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- ── 다음 이벤트 ─────────────────────────────────────────────── -->
            <div class="section-card">
                <div class="section-card-header">다음 이벤트</div>
                <div class="section-card-body">
                    <div class="form-group">
                        <label>NextEventMode</label>
                        <select value="@evt.NextEventMode" @onchange="@(e => SetNextMode(evt, e))">
                            <option value="Specific">Specific — 순서대로 조건 통과한 첫 번째</option>
                            <option value="Conditional">Conditional — 조건부 엔트리 평가</option>
                            <option value="Random">Random — 조건 통과 중 랜덤</option>
                        </select>
                    </div>

                    @if (evt.NextEventMode != NextEventMode.Conditional)
                    {
                        <div>
                            <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                <span class="text-xs text-dim" style="font-weight:700">다음 이벤트 Keys (@evt.NextEventKeys.Count)</span>
                                <button class="btn btn-secondary btn-sm"
                                        @onclick="() => evt.NextEventKeys.Add(0)">+ Key 추가</button>
                            </div>
                            @if (evt.NextEventKeys.Count == 0)
                            { <div class="text-dim text-sm">비어있으면 전체 이벤트 풀에서 랜덤</div> }
                            @for (int ki = 0; ki < evt.NextEventKeys.Count; ki++)
                            {
                                int kIdx = ki;
                                <div class="inline-row" style="margin-bottom:6px">
                                    <select value="@evt.NextEventKeys[kIdx]"
                                            @onchange="@(e => SetNextKey(evt, kIdx, e))">
                                        <option value="0">(이벤트 선택)</option>
                                        @foreach (var e2 in Store.GameEvents.OrderBy(e => e.Key))
                                        {
                                            <option value="@e2.Key">Key @e2.Key</option>
                                        }
                                    </select>
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => evt.NextEventKeys.RemoveAt(kIdx)">×</button>
                                </div>
                            }
                        </div>
                    }

                    @if (evt.NextEventMode == NextEventMode.Conditional)
                    {
                        <div>
                            <div class="d-flex justify-between align-center" style="margin-bottom:6px">
                                <span class="text-xs text-dim" style="font-weight:700">조건부 엔트리 (@evt.NextEventEntries.Count)</span>
                                <button class="btn btn-secondary btn-sm"
                                        @onclick="() => evt.NextEventEntries.Add(new NextEventEntry())">+ 엔트리 추가</button>
                            </div>
                            @for (int ni = 0; ni < evt.NextEventEntries.Count; ni++)
                            {
                                int nIdx = ni;
                                var entry = evt.NextEventEntries[nIdx];
                                <div class="sub-item">
                                    <div class="sub-item-header">
                                        <span>엔트리 #@(nIdx+1)</span>
                                        <button class="btn btn-danger btn-sm"
                                                @onclick="() => evt.NextEventEntries.RemoveAt(nIdx)">×</button>
                                    </div>
                                    <div class="form-group">
                                        <label>목표 이벤트 Key</label>
                                        <select value="@entry.EventKey"
                                                @onchange="@(e => SetEntryKey(entry, e))">
                                            <option value="0">(이벤트 선택)</option>
                                            @foreach (var e2 in Store.GameEvents.OrderBy(e => e.Key))
                                            {
                                                <option value="@e2.Key">Key @e2.Key</option>
                                            }
                                        </select>
                                    </div>
                                    <div>
                                        <div class="d-flex justify-between align-center" style="margin-bottom:4px">
                                            <span class="text-xs text-dim">조건 (@entry.Conditions.Count)</span>
                                            <button class="btn btn-secondary btn-sm"
                                                    @onclick="() => entry.Conditions.Add(new EventCondition())">+ 조건</button>
                                        </div>
                                        @for (int eci = 0; eci < entry.Conditions.Count; eci++)
                                        {
                                            int ecIdx = eci;
                                            var cond = entry.Conditions[ecIdx];
                                            <div class="sub-item" style="background:rgba(0,0,0,0.2)">
                                                <div class="sub-item-header">
                                                    <span>조건 #@(ecIdx+1)</span>
                                                    <button class="btn btn-danger btn-sm"
                                                            @onclick="() => entry.Conditions.RemoveAt(ecIdx)">×</button>
                                                </div>
                                                @ConditionEditor(cond)
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    GameEventData? _selected;

    // ─── CRUD ──────────────────────────────────────────────────────────────

    void CreateEvent()
    {
        long nextKey = Store.GameEvents.Count > 0
            ? Math.Max(900000L, Store.GameEvents.Max(e => e.Key) + 1)
            : 900000L;
        var evt = new GameEventData
        {
            Key = nextKey,
            ContentBlocks = new() { new EventContentBlock() }
        };
        Store.GameEvents.Add(evt);
        _selected = evt;
    }

    void DeleteEvent(GameEventData evt)
    {
        Store.GameEvents.Remove(evt);
        if (_selected == evt) _selected = null;
    }

    // ─── 필드 세터 ──────────────────────────────────────────────────────────

    void SetEvtKey(GameEventData evt, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) evt.Key = v; }

    void SetNextMode(GameEventData evt, ChangeEventArgs e)
    { if (Enum.TryParse<NextEventMode>(e.Value?.ToString(), out var v)) evt.NextEventMode = v; }

    void SetNextKey(GameEventData evt, int idx, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) evt.NextEventKeys[idx] = v; }

    void SetEntryKey(NextEventEntry entry, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) entry.EventKey = v; }

    void SetContentItemType(EventContentItem item, ChangeEventArgs e)
    { if (Enum.TryParse<ContentItemType>(e.Value?.ToString(), out var v)) item.Type = v; }

    void SetSelVictoryKey(EventSelection sel, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) sel.BattleVictoryEventKey = v; }

    void SetSelDefeatKey(EventSelection sel, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) sel.BattleDefeatEventKey = v; }

    // ─── 조건 에디터 ─────────────────────────────────────────────────────────

    RenderFragment ConditionEditor(EventCondition cond) =>
    @<div>
        <div class="inline-row">
            <div class="form-group">
                <label>DataType</label>
                <select value="@cond.DataType" @onchange="@(e => SetCondDataType(cond, e))">
                    @foreach (var v in Enum.GetValues<GameDataType>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>DataKey</label>
                <input type="number" value="@cond.DataKey"
                       @onchange="@(e => SetCondDataKey(cond, e))" />
            </div>
        </div>
        <div class="inline-row">
            <div class="form-group">
                <label>Operator</label>
                <select value="@cond.Op" @onchange="@(e => SetCondOp(cond, e))">
                    @foreach (var v in Enum.GetValues<ConditionOperator>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>CompareValue</label>
                <input type="number" value="@cond.CompareValue"
                       @onchange="@(e => SetCondCompare(cond, e))" />
            </div>
        </div>
    </div>;

    void SetCondDataType(EventCondition c, ChangeEventArgs e)
    { if (Enum.TryParse<GameDataType>(e.Value?.ToString(), out var v)) c.DataType = v; }
    void SetCondDataKey(EventCondition c, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) c.DataKey = v; }
    void SetCondOp(EventCondition c, ChangeEventArgs e)
    { if (Enum.TryParse<ConditionOperator>(e.Value?.ToString(), out var v)) c.Op = v; }
    void SetCondCompare(EventCondition c, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) c.CompareValue = v; }

    // ─── 효과 에디터 ─────────────────────────────────────────────────────────

    RenderFragment EffectEditor(EventEffect eff) =>
    @<div>
        <div class="inline-row">
            <div class="form-group">
                <label>DataType</label>
                <select value="@eff.DataType" @onchange="@(e => SetEffDataType(eff, e))">
                    @foreach (var v in Enum.GetValues<GameDataType>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>DataKey</label>
                <input type="number" value="@eff.DataKey"
                       @onchange="@(e => SetEffDataKey(eff, e))" />
            </div>
        </div>
        <div class="inline-row">
            <div class="form-group">
                <label>Operator</label>
                <select value="@eff.Op" @onchange="@(e => SetEffOp(eff, e))">
                    @foreach (var v in Enum.GetValues<EffectOperator>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>Value</label>
                <input type="number" value="@eff.Value"
                       @onchange="@(e => SetEffValue(eff, e))" />
            </div>
        </div>
    </div>;

    void SetEffDataType(EventEffect ef, ChangeEventArgs e)
    { if (Enum.TryParse<GameDataType>(e.Value?.ToString(), out var v)) ef.DataType = v; }
    void SetEffDataKey(EventEffect ef, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) ef.DataKey = v; }
    void SetEffOp(EventEffect ef, ChangeEventArgs e)
    { if (Enum.TryParse<EffectOperator>(e.Value?.ToString(), out var v)) ef.Op = v; }
    void SetEffValue(EventEffect ef, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) ef.Value = v; }
}
