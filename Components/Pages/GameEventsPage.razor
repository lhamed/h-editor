                        <div class="form-group">
                            <label>패배 후 이벤트 Key</label>
                            <input type="number"
                                   value="@nestedSel.BattleDefeatEventKey"
                                   @onchange="@(e => SetSelDefeatKey(nestedSel, e))" />
                        </div>
                    </div>
                    @{
                        nestedSel.UIEffect ??= new EventUIEffectSettings();
                    }
                    @UIEffectEditor("선택지 UI 이펙트", nestedSel.UIEffect, panelOptions: false, buttonOptions: true)
                </div>
            }
        </div>
    </div>;

    RenderFragment UIEffectEditor(string title, EventUIEffectSettings effect, bool panelOptions, bool buttonOptions) =>
    @<div class="sub-item" style="background:var(--subtle-bg);margin-top:8px">
        <div class="sub-item-header">
            <span>@title</span>
            <span class="text-xs text-dim">선택형</span>
        </div>
        <div class="form-check" style="margin-bottom:8px">
            <input type="checkbox" @bind="effect.OverrideEffects" />
            <label>이 항목에서 UI 이펙트 설정</label>
        </div>

        @if (effect.OverrideEffects)
        {
            @if (panelOptions)
            {
                <div class="inline-row">
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.PanelScale" />
                        <label>Scale Open</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.PanelScaleWidth" disabled="@(!effect.PanelScale)" />
                        <label>Width</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.PanelScaleHeight" disabled="@(!effect.PanelScale)" />
                        <label>Height</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.FadeIn" />
                        <label>Fade In</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.FadeOut" />
                        <label>Fade Out</label>
                    </div>
                </div>
            }

            @if (buttonOptions)
            {
                <div class="inline-row">
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.ButtonClickScale" />
                        <label>Button Click Scale</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.ButtonFadePulse" />
                        <label>Button Fade Pulse</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" @bind="effect.ButtonActive" />
                        <label>Button Active</label>
                    </div>
                </div>
            }

            <div class="form-group" style="margin-top:6px">
                <label>SFX</label>
                <input type="text" @bind="effect.SfxName" placeholder="AudioClip 이름" />
            </div>
        }
    </div>;

    // ─── 미리보기 ─────────────────────────────────────────────────────────

    RenderFragment PreviewPanel(GameEventData evt, List<string> langs) =>
    @<div>
        @{
            // 언어 초기화
            if (string.IsNullOrEmpty(_previewLang) && langs.Count > 0)
                _previewLang = langs[0];

            // 블록 인덱스 범위 보정
            int blockCount = evt.ContentBlocks.Count;
            if (_previewBlockIdx >= blockCount) _previewBlockIdx = Math.Max(0, blockCount - 1);
            var block = blockCount > 0 ? evt.ContentBlocks[_previewBlockIdx] : null;

            string T(string key) => (!string.IsNullOrEmpty(_previewLang) ? Store.LookupText(key, _previewLang) : null) ?? key;
        }

        <!-- 언어 선택 + 블록 네비게이션 -->
        <div class="preview-toolbar">
            <div class="d-flex align-center gap-2">
                <span class="text-xs text-dim">언어</span>
                @if (langs.Count > 0)
                {
                    <select style="width:auto;padding:4px 8px;font-size:12px"
                            value="@_previewLang" @onchange="@(e => _previewLang = e.Value?.ToString() ?? "")">
                        @foreach (var l in langs)
                        { <option value="@l">@l</option> }
                    </select>
                }
                else
                {
                    <span class="badge badge-warning">M.bytes 미로드 — 홈에서 업로드하세요</span>
                }
            </div>
            @if (blockCount > 1)
            {
                <div class="d-flex align-center gap-2">
                    <button class="btn btn-secondary btn-sm"
                            disabled="@(_previewBlockIdx == 0)"
                            @onclick="() => _previewBlockIdx--">◀</button>
                    <span class="text-xs">블록 @(_previewBlockIdx + 1) / @blockCount</span>
                    <button class="btn btn-secondary btn-sm"
                            disabled="@(_previewBlockIdx >= blockCount - 1)"
                            @onclick="() => _previewBlockIdx++">▶</button>
                </div>
            }
        </div>

        @if (block == null)
        {
            <div class="preview-empty">콘텐츠 블록이 없습니다</div>
        }
        else
        {
            <div class="preview-scene">
                <!-- 콘텐츠 아이템 -->
                @foreach (var item in block.ContentItems)
                {
                    @if (item.Type == ContentItemType.Dialogue)
                    {
                        <div class="preview-dialogue">
                            <div class="preview-dialogue-portrait">
                                @if (!string.IsNullOrEmpty(item.ExpressionPath))
                                {
                                    <div class="preview-portrait-path" title="@item.ExpressionPath">🖼</div>
                                }
                                else
                                {
                                    <div class="preview-portrait-empty">?</div>
                                }
                            </div>
                            <div class="preview-dialogue-bubble">
                                @if (!string.IsNullOrEmpty(item.SpeakerNameKey))
                                {
                                    <div class="preview-speaker">@T(item.SpeakerNameKey)</div>
                                }
                                <div class="preview-dialogue-text">@T(item.TextKey)</div>
                            </div>
                        </div>
                    }
                    else if (item.Type == ContentItemType.Image)
                    {
                        <div class="preview-image-view">
                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <div class="preview-image-path" title="@item.ImagePath">🖼 @item.ImagePath</div>
                            }
                            else
                            {
                                <div class="preview-image-empty">[이미지 없음]</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="preview-narration">@T(item.TextKey)</div>
                    }
                }

                <!-- 공통 효과 -->
                @if (block.CommonEffects.Count > 0)
                {
                    <div class="preview-effects">
                        <span class="text-xs text-dim">효과: </span>
                        @foreach (var ef in block.CommonEffects)
                        {
                            var opStr = ef.Op switch {
                                EffectOperator.Add      => "+",
                                EffectOperator.Subtract => "-",
                                _                       => "="
                            };
                            <span class="preview-effect-chip">@ef.DataType #@ef.DataKey @opStr @ef.Value</span>
                        }
                    </div>
                }

                <!-- 선택지 -->
                @if (block.Selections.Count > 0)
                {
                    <div class="preview-selections">
                        @foreach (var sel in block.Selections)
                        {
                            <div class="preview-sel-btn">
                                <span>@T(sel.SelectionTextKey)</span>
                                @if (sel.BattleVictoryEventKey != 0)
                                {
                                    <span class="text-xs text-dim" style="margin-left:6px">⚔ 배틀</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-dim text-xs" style="margin-top:12px">— 선택지 없음 (자동 진행) —</div>
                }
            </div>

            <!-- 다음 이벤트 힌트 -->
            @if (evt.NextEventKeys.Count > 0 || evt.NextEventEntries.Count > 0)
            {
                <div class="preview-next">
                    <span class="text-xs text-dim">다음 이벤트: </span>
                    @if (evt.NextEventMode == NextEventMode.Conditional)
                    {
                        @foreach (var en in evt.NextEventEntries)
                        {
                            <span class="preview-next-chip">Key @en.EventKey (@(en.Conditions.Count)조건)</span>
                        }
                    }
                    else
                    {
                        @foreach (var k in evt.NextEventKeys)
                        {
                            <span class="preview-next-chip">Key @k</span>
                        }
                    }
                    <span class="text-xs text-dim">[@evt.NextEventMode]</span>
                </div>
            }
        }
    </div>;

    // ─── 조건 에디터 ─────────────────────────────────────────────────────────

    RenderFragment ConditionEditor(EventCondition cond) =>
    @<div>
        <div class="inline-row">
            <div class="form-group">
                <label>DataType</label>
                <select value="@cond.DataType" @onchange="@(e => SetCondDataType(cond, e))">
                    @foreach (var v in Enum.GetValues<GameDataType>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>DataKey</label>
                @if (cond.DataType == GameDataType.Stat)
                {
                    <select value="@cond.DataKey" @onchange="@(e => SetCondDataKey(cond, e))">
                        @foreach (var stat in PlayerStatOptions)
                        { <option value="@stat.Key">@stat.Label</option> }
                    </select>
                }
                else
                {
                    <input type="number" value="@cond.DataKey"
                           @onchange="@(e => SetCondDataKey(cond, e))" />
                }
            </div>
        </div>
        <div class="inline-row">
            <div class="form-group">
                <label>Operator</label>
                <select value="@cond.Op" @onchange="@(e => SetCondOp(cond, e))">
                    @foreach (var v in Enum.GetValues<ConditionOperator>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>CompareValue</label>
                <input type="number" value="@cond.CompareValue"
                       @onchange="@(e => SetCondCompare(cond, e))" />
            </div>
        </div>
    </div>;

    void SetCondDataType(EventCondition c, ChangeEventArgs e)
    {
        if (Enum.TryParse<GameDataType>(e.Value?.ToString(), out var v))
        {
            c.DataType = v;
            if (v == GameDataType.Stat && !PlayerStatOptions.Any(s => s.Key == c.DataKey))
                c.DataKey = 0;
        }
    }
    void SetCondDataKey(EventCondition c, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) c.DataKey = v; }
    void SetCondOp(EventCondition c, ChangeEventArgs e)
    { if (Enum.TryParse<ConditionOperator>(e.Value?.ToString(), out var v)) c.Op = v; }
    void SetCondCompare(EventCondition c, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) c.CompareValue = v; }

    // ─── 효과 에디터 ─────────────────────────────────────────────────────────

    RenderFragment EffectEditor(EventEffect eff) =>
    @<div>
        <div class="inline-row">
            <div class="form-group">
                <label>DataType</label>
                <select value="@eff.DataType" @onchange="@(e => SetEffDataType(eff, e))">
                    @foreach (var v in Enum.GetValues<GameDataType>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>DataKey</label>
                @if (eff.DataType == GameDataType.Stat)
                {
                    <select value="@eff.DataKey" @onchange="@(e => SetEffDataKey(eff, e))">
                        @foreach (var stat in PlayerStatOptions)
                        { <option value="@stat.Key">@stat.Label</option> }
                    </select>
                }
                else
                {
                    <input type="number" value="@eff.DataKey"
                           @onchange="@(e => SetEffDataKey(eff, e))" />
                }
            </div>
        </div>
        <div class="inline-row">
            <div class="form-group">
                <label>Operator</label>
                <select value="@eff.Op" @onchange="@(e => SetEffOp(eff, e))">
                    @foreach (var v in Enum.GetValues<EffectOperator>())
                    { <option value="@v">@v</option> }
                </select>
            </div>
            <div class="form-group">
                <label>Value</label>
                <input type="number" value="@eff.Value"
                       @onchange="@(e => SetEffValue(eff, e))" />
            </div>
        </div>
    </div>;

    void SetEffDataType(EventEffect ef, ChangeEventArgs e)
    {
        if (Enum.TryParse<GameDataType>(e.Value?.ToString(), out var v))
        {
            ef.DataType = v;
            if (v == GameDataType.Stat && !PlayerStatOptions.Any(s => s.Key == ef.DataKey))
                ef.DataKey = 0;
        }
    }
    void SetEffDataKey(EventEffect ef, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) ef.DataKey = v; }
    void SetEffOp(EventEffect ef, ChangeEventArgs e)
    { if (Enum.TryParse<EffectOperator>(e.Value?.ToString(), out var v)) ef.Op = v; }
    void SetEffValue(EventEffect ef, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) ef.Value = v; }

    static readonly (long Key, string Label)[] PlayerStatOptions =
    {
        (0, "정신력"),
        (1, "체력"),
        (2, "완력"),
        (3, "민첩성")
    };
}
