@page "/battle-data"
@inject DataStore Store

<PageTitle>배틀 데이터 — H-Editor</PageTitle>

<div class="page-layout">
    @{
        var filteredBattles = FilteredBattles().ToList();
    }

    <!-- ─── 목록 ─────────────────────────────────────────────────────────── -->
    <div class="list-panel">
        <div class="list-panel-header">
            <span>배틀 데이터 (@filteredBattles.Count / @Store.BattleDatas.Count)</span>
            <button class="btn btn-success btn-sm" @onclick="CreateBattle">+ 새로 만들기</button>
        </div>
        <div class="list-search">
            <input type="search"
                   @bind="_battleSearch"
                   @bind:event="oninput"
                   placeholder="배틀 Key, 그룹 Key, 몬스터 이름 검색" />
        </div>
        <div class="list-scroll">
            @if (!Store.BattleDatas.Any())
            {
                <div class="list-empty">배틀 데이터가 없습니다.</div>
            }
            else if (filteredBattles.Count == 0)
            {
                <div class="list-empty">검색 결과가 없습니다.</div>
            }
            @foreach (var b in filteredBattles)
            {
                var group = Store.GetGroup(b.MonsterGroupKey);
                <div class="list-item @(_selected == b ? "active" : "")" @onclick="() => _selected = b">
                    <div class="list-item-key">Key: @b.Key</div>
                    <div class="list-item-name">
                        @if (group != null) { <span>그룹 [@b.MonsterGroupKey] @(group.MemberKeys.Count)명</span> }
                        else if (b.MonsterGroupKey > 0) { <span class="text-danger">그룹 Key @b.MonsterGroupKey 없음</span> }
                        else { <span class="text-dim">(그룹 없음)</span> }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ─── 상세 편집 ─────────────────────────────────────────────────────── -->
    @if (_selected == null)
    {
        <div class="empty-detail">배틀 데이터를 선택하거나 새로 만드세요</div>
    }
    else
    {
        var battle = _selected;
        var group = Store.GetGroup(battle.MonsterGroupKey);
        var firstLang = Store.GetLanguageColumns().FirstOrDefault();

        <div class="detail-panel">
            <div class="detail-header">
                <span class="detail-header-icon">⚔️</span>
                <span class="detail-header-title">BattleData 편집</span>
                <span class="detail-header-key">KEY @battle.Key</span>
                <button class="btn btn-danger btn-sm" @onclick="() => DeleteBattle(battle)">삭제</button>
            </div>

            <div class="inspector-jumpbar">
                <a class="btn btn-ghost btn-sm" href="#battle-key">Key</a>
                <a class="btn btn-ghost btn-sm" href="#battle-group">몬스터 그룹</a>
            </div>

            <!-- Key -->
            <div class="section-card" id="battle-key">
                <div class="section-card-header">Key</div>
                <div class="section-card-body">
                    <input type="number"
                           value="@battle.Key"
                           @onchange="@(e => SetBattleKey(battle, e))"
                           class="@(Store.HasDuplicateBattleKey(battle.Key, battle) ? "key-invalid" : battle.Key > 0 ? "key-valid" : "key-missing")" />
                    @if (Store.HasDuplicateBattleKey(battle.Key, battle))
                    { <div class="text-danger text-xs mt-1">중복 Key 존재</div> }
                </div>
            </div>

            <!-- 몬스터 그룹 -->
            <div class="section-card" id="battle-group">
                <div class="section-card-header">몬스터 그룹</div>
                <div class="section-card-body">
                    <div class="form-group">
                        <label>Monster Group</label>
                        <select value="@battle.MonsterGroupKey"
                                @onchange="@(e => SetMonsterGroup(battle, e))">
                            <option value="0">(없음 — 즉시 승리)</option>
                            @foreach (var g in Store.MonsterGroups.OrderBy(g => g.Key))
                            {
                                <option value="@g.Key">[@g.Key] 멤버 @(g.MemberKeys.Count)명</option>
                            }
                        </select>
                    </div>

                    @if (battle.MonsterGroupKey == 0)
                    {
                        <div class="alert alert-warning">MonsterGroup이 없으면 전투가 즉시 승리로 처리됩니다.</div>
                    }
                    else if (group == null)
                    {
                        <div class="alert alert-danger">Key @battle.MonsterGroupKey 몬스터 그룹을 찾을 수 없습니다.</div>
                    }
                    else
                    {
                        <div class="section-block" style="margin-top:8px">
                            <div class="section-block-title">멤버 미리보기</div>
                            @if (group.MemberKeys.Count == 0)
                            {
                                <div class="text-dim text-sm">(멤버 없음)</div>
                            }
                            @foreach (var mKey in group.MemberKeys)
                            {
                                var m = Store.GetMonster(mKey);
                                <div class="text-sm" style="padding:3px 0;border-bottom:1px solid var(--border)">
                                    @if (m != null)
                                    {
                                        var nameP = firstLang != null ? Store.LookupText(m.NameKey, firstLang) : null;
                                        <span>· [@m.Key] @(nameP ?? m.NameKey)  HP @m.MaxHP / ATK @m.AttackPower / EVA @m.Evasion</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">· Key @mKey 몬스터 없음</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    BattleDataModel? _selected;
    string _battleSearch = "";

    void CreateBattle()
    {
        long nextKey = Store.BattleDatas.Count > 0 ? Store.BattleDatas.Max(b => b.Key) + 1 : 1;
        var b = new BattleDataModel { Key = nextKey };
        Store.BattleDatas.Add(b);
        _selected = b;
    }

    void DeleteBattle(BattleDataModel b)
    {
        Store.BattleDatas.Remove(b);
        if (_selected == b) _selected = null;
    }

    void SetBattleKey(BattleDataModel b, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) b.Key = v; }

    void SetMonsterGroup(BattleDataModel b, ChangeEventArgs e)
    { if (long.TryParse(e.Value?.ToString(), out long v)) b.MonsterGroupKey = v; }

    IEnumerable<BattleDataModel> FilteredBattles()
    {
        var battles = Store.BattleDatas.OrderBy(b => b.Key);
        var query = _battleSearch.Trim();
        if (string.IsNullOrWhiteSpace(query))
            return battles;

        var lang = Store.GetLanguageColumns().FirstOrDefault();
        return battles.Where(battle => BattleMatches(battle, query, lang));
    }

    bool BattleMatches(BattleDataModel battle, string query, string? lang)
    {
        if (battle.Key.ToString().Contains(query, StringComparison.OrdinalIgnoreCase) ||
            battle.MonsterGroupKey.ToString().Contains(query, StringComparison.OrdinalIgnoreCase))
            return true;

        var group = Store.GetGroup(battle.MonsterGroupKey);
        if (group == null)
            return false;

        foreach (var memberKey in group.MemberKeys)
        {
            if (memberKey.ToString().Contains(query, StringComparison.OrdinalIgnoreCase))
                return true;

            var monster = Store.GetMonster(memberKey);
            if (monster != null && TextMatches(monster.NameKey, query, lang))
                return true;
        }

        return false;
    }

    bool TextMatches(string key, string query, string? lang)
    {
        if (!string.IsNullOrWhiteSpace(key) &&
            key.Contains(query, StringComparison.OrdinalIgnoreCase))
            return true;

        if (!string.IsNullOrWhiteSpace(lang))
        {
            var text = Store.LookupText(key, lang);
            return !string.IsNullOrWhiteSpace(text) &&
                   text.Contains(query, StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }
}
